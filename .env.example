# ---------------------------------------------------------------
# Copier ce fichier en .env et remplir avec de vraies valeurs.
# Ne JAMAIS committer .env.
# ---------------------------------------------------------------

# --- Whisper (transcription audio → sous-titres) ---
# Par défaut : OpenAI hosted.
OPENAI_API_KEY=sk-replace-me
# Pour pointer vers un Whisper self-hosted (API compatible OpenAI), exemples :
#   OPENAI_BASE_URL=http://192.168.1.50:8080/v1     # whisper.cpp server
#   OPENAI_BASE_URL=http://localhost:8000/v1         # faster-whisper-server
#   OPENAI_BASE_URL=http://localhost:8080/v1         # LocalAI
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Auth de l'API json2video ---
# Génère une valeur forte : openssl rand -hex 32
SECRET_API_KEY=change-me-to-a-long-random-string

# --- Server config ---
NODE_PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
MAX_UPLOAD_MB=200

# --- Chemins binaires (optionnel — utile si plusieurs ffmpeg installés) ---
# macOS Homebrew avec ffmpeg-full :
#   FFMPEG_BIN=/opt/homebrew/opt/ffmpeg-full/bin/ffmpeg
#   FFPROBE_BIN=/opt/homebrew/opt/ffmpeg-full/bin/ffprobe
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe
# PYTHON_BIN=python3

# --- Queue de jobs (optionnel) ---
# RENDER_CONCURRENCY=1

# ---------------------------------------------------------------
# OPTIONNEL : legacy Flask pipeline (app.py + Google Speech-to-Text)
# Ne décommenter QUE si tu fais tourner aussi l'API Flask en parallèle
# du Node. Le pipeline Node n'a besoin d'aucune de ces variables.
# ---------------------------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
# GCS_BUCKET=mon-bucket
# FLASK_PORT=5001
# FLASK_HOST=127.0.0.1
# FLASK_DEBUG=0
# MONITOR_USERNAME=admin
# MONITOR_PASSWORD=change-me

# ---------------------------------------------------------------
# Copier ce fichier en .env et remplir avec de vraies valeurs.
# Ne JAMAIS committer .env.
# ---------------------------------------------------------------

# --- OpenAI (Whisper transcription, utilisé par server.js) ---
OPENAI_API_KEY=sk-replace-me

# --- Google Cloud (Speech-to-Text + GCS, utilisé par app.py) ---
# Chemin vers le JSON du service account
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
# Bucket GCS utilisé pour les transcriptions de fichiers audio longs
GCS_BUCKET=my-bucket-name

# --- Application API key (auth des endpoints Flask) ---
SECRET_API_KEY=change-me-to-a-long-random-string

# --- Monitoring / logs (Basic auth sur /monitor et /logs) ---
MONITOR_USERNAME=admin
MONITOR_PASSWORD=change-me-to-a-strong-password

# --- Server config ---
NODE_PORT=3000
FLASK_PORT=5001
PUBLIC_BASE_URL=http://localhost:3000

# --- Optionnel : chemin vers python3 si non disponible dans PATH ---
# PYTHON_BIN=/usr/bin/python3

{
  "name": "youtube-captions",
  "label": "YouTube — sous-titres classiques",
  "format": "16:9",
  "fps": 30,
  "background": "#000000",
  "default_media": {
    "duration": "auto",
    "fit": "cover"
  },
  "subtitle": {
    "mode": "captions",
    "language": "fr",
    "style": {
      "fontname": "DejaVu Sans",
      "fontsize": 48,
      "primary_color": [255, 255, 255, 0],
      "outline_color": [0, 0, 0, 0],
      "back_color": [0, 0, 0, 160],
      "alignment": 2,
      "margin_v": 80,
      "outline": 2,
      "shadow": 1,
      "bold": false,
      "max_words_per_line": 8
    }
  },
  "output": {
    "preset": "medium",
    "crf": 20
  }
}

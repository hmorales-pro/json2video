# ---------------------------------------------------------------
# Secrets — NEVER commit these
# ---------------------------------------------------------------
.env
.env.*
!.env.example

# (config.py est maintenant safe : il ne fait que lire os.getenv().
#  On le garde versionné comme template pour les autres devs.)

# Google Cloud credentials (service account & OAuth client)
client_secret*.json
*-credentials.json
*service-account*.json
google-credentials.json
gcp-*.json
# Project-specific credential files (UUID-style names)
json2video-*.json

# AWS credentials
.aws/
credentials

# ---------------------------------------------------------------
# Python
# ---------------------------------------------------------------
# ⚠️  Pas de "lib/" ici ! Notre code Node utilise lib/ pour ses modules.
# Les patterns "lib/", "lib64/", "parts/", "var/" etc. viennent du
# packaging Python et casseraient le déploiement de l'API.
__pycache__/
*.py[cod]
*$py.class
venv/
ENV/
env/
.Python
.eggs/
*.egg-info/
*.egg
.installed.cfg
build/dist/

# ---------------------------------------------------------------
# Node
# ---------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------
# Logs & temporaires
# ---------------------------------------------------------------
*.log
nohup.out
pip-log.txt
pip-delete-this-directory.txt
.cache/
.mypy_cache/

# ---------------------------------------------------------------
# Éditeurs / OS
# ---------------------------------------------------------------
.vscode/
.idea/
.DS_Store
**/.DS_Store
Thumbs.db

# ---------------------------------------------------------------
# Inputs / outputs de l'application
# ---------------------------------------------------------------
uploads/
outputs/
!uploads/.gitkeep
!outputs/.gitkeep

{
  "info": {
    "name": "json2video — complète",
    "description": "Collection exhaustive couvrant chaque paramètre disponible.\n\n## Setup\n\n1. Importer aussi `json2video.postman_environment.json`.\n2. Sélectionner l'environnement « json2video — local » (top droite).\n3. Remplir la variable `secret_api_key` avec la valeur de ton `.env`.\n4. Démarrer le serveur : `npm start` (port 3000).\n\nDans chaque requête `/render`, attache tes fichiers dans les champs marqués `[FILE]` (clique sur \"Select Files\").\n\n## Conventions multipart\n\n- `config` (text) : ta config JSON (voir descriptions)\n- `audio` (file) : voix-off (mp3/wav/m4a)\n- `music` (file) : musique de fond (optionnel)\n- `media_0`, `media_1`, ... : médias dans l'ordre (images ou vidéos)\n\nLa variable `last_job_id` est remplie automatiquement après /render/async.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "x-api-key", "type": "string" },
      { "key": "value", "value": "{{secret_api_key}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "0. Health & discovery",
      "item": [
        {
          "name": "GET / — healthcheck (no auth)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/", "host": ["{{base_url}}"], "path": [""] },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "GET /templates",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/templates", "host": ["{{base_url}}"], "path": ["templates"] }
          }
        },
        {
          "name": "GET /formats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/formats", "host": ["{{base_url}}"], "path": ["formats"] }
          }
        }
      ]
    },
    {
      "name": "1. Templates de base",
      "item": [
        {
          "name": "Template reels-karaoke (9:16, karaoké)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\"}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "", "description": "[FILE] image" },
                { "key": "media_1", "type": "file", "src": "", "description": "[FILE] image" },
                { "key": "media_2", "type": "file", "src": "", "description": "[FILE] image" },
                { "key": "audio",   "type": "file", "src": "", "description": "[FILE] voix-off" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "Template youtube-captions (16:9, captions)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"youtube-captions\"}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "Template square-quote (1:1)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"square-quote\"}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "Template tiktok-storytime (9:16, karaoké centré)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"tiktok-storytime\"}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "media_1", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        }
      ]
    },
    {
      "name": "2. Gestion audio (audio_handling)",
      "item": [
        {
          "name": "extend — freeze last (DÉFAUT)",
          "request": {
            "method": "POST",
            "description": "Si l'audio dépasse la séquence, le dernier média est étendu : image plus longue, ou freeze frame pour une vidéo.",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"audio_handling\":\"extend\"}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "media_1", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "loop — boucle dernière vidéo",
          "request": {
            "method": "POST",
            "description": "Si le dernier média est une vidéo et l'audio plus long, la vidéo se rejoue en boucle.",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"audio_handling\":\"loop\"}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "", "description": "[FILE] image intro" },
                { "key": "media_1", "type": "file", "src": "", "description": "[FILE] vidéo qui sera bouclée" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "loop_all — boucle toute la séquence",
          "request": {
            "method": "POST",
            "description": "Toute la séquence se répète jusqu'à couvrir l'audio. Cappé à K=50 répétitions.",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"audio_handling\":\"loop_all\"}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "media_1", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "cut — audio coupé à la fin du visuel",
          "request": {
            "method": "POST",
            "description": "Ancien comportement (-shortest). L'audio est coupé à la fin de la dernière vidéo.",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"audio_handling\":\"cut\"}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        }
      ]
    },
    {
      "name": "3. Transitions xfade",
      "item": [
        {
          "name": "fade (classique)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"transitions\":{\"type\":\"fade\",\"duration\":0.4}}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "media_1", "type": "file", "src": "" },
                { "key": "media_2", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "dissolve",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"transitions\":{\"type\":\"dissolve\",\"duration\":0.5}}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "media_1", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "slideleft (cinétique)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"transitions\":{\"type\":\"slideleft\",\"duration\":0.6}}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "media_1", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "fadeblack (coupure dramatique)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"transitions\":{\"type\":\"fadeblack\",\"duration\":0.8}}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "media_1", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "Toutes les valeurs possibles",
          "request": {
            "method": "GET",
            "url": { "raw": "data:none", "host": ["data:none"] }
          },
          "description": "Types disponibles : none, fade, fadeblack, fadewhite, dissolve, wipeleft, wiperight, wipeup, wipedown, slideleft, slideright, slideup, slidedown, smoothleft, smoothright, smoothup, smoothdown, circlecrop, rectcrop, distance, radial, zoomin\n\nDurée : 0.1 à 2.0 secondes."
        }
      ]
    },
    {
      "name": "4. Modes de sous-titres",
      "item": [
        {
          "name": "subtitle.mode = none (sans sous-titres)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"subtitle\":{\"mode\":\"none\"}}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }

          "name": "subtitle.mode = karaoke (mot-à-mot)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"subtitle\":{\"mode\":\"karaoke\",\"language\":\"fr\"}}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "Style sous-titres custom (taille, couleurs, position)",
          "request": {
            "method": "POST",
            "description": "Override complet du style : police, taille, couleurs RGBA, alignement, marge, contour, ombre, gras, mots/ligne.",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "config",
                  "value": "{\n  \"template\": \"reels-karaoke\",\n  \"subtitle\": {\n    \"mode\": \"karaoke\",\n    \"language\": \"fr\",\n    \"style\": {\n      \"fontname\": \"DejaVu Sans\",\n      \"fontsize\": 56,\n      \"primary_color\": [255,255,255,0],\n      \"secondary_color\": [255,200,0,0],\n      \"outline_color\": [0,0,0,0],\n      \"back_color\": [0,0,0,160],\n      \"alignment\": 2,\n      \"margin_v\": 200,\n      \"outline\": 3,\n      \"shadow\": 2,\n      \"bold\": true,\n      \"max_words_per_line\": 3\n    }\n  }\n}",
                  "type": "text"
                },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        }
      ]
    },
    {
      "name": "5. Mix audio (voix + musique)",
      "item": [
        {
          "name": "Voix-off seule",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"audio\":{\"voice_volume\":1.0}}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "", "description": "[FILE] voix-off" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "Voix + musique (mix simple)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"audio\":{\"voice_volume\":1.0,\"music_volume\":0.3}}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "", "description": "[FILE] voix-off" },
                { "key": "music",   "type": "file", "src": "", "description": "[FILE] musique de fond" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "Voix + musique + ducking automatique",
          "request": {
            "method": "POST",
            "description": "La musique baisse automatiquement quand la voix est présente (sidechain compress).",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"audio\":{\"voice_volume\":1.1,\"music_volume\":0.4,\"ducking\":true}}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" },
                { "key": "music",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        }
      ]
    },
    {
      "name": "6. Overlays texte",
      "item": [
        {
          "name": "Un overlay simple (titre en haut)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "config",
                  "value": "{\n  \"template\": \"reels-karaoke\",\n  \"overlays\": [\n    {\n      \"type\": \"text\",\n      \"text\": \"NOUVEAU\",\n      \"x\": \"center\",\n      \"y\": \"top\",\n      \"fontsize\": 60,\n      \"color\": \"#FFFFFF\",\n      \"bg_color\": \"#FF0000\",\n      \"bg_opacity\": 0.85\n    }\n  ]\n}",
                  "type": "text"
                },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "Plusieurs overlays avec timing",
          "request": {
            "method": "POST",
            "description": "Overlays affichés sur des plages temporelles spécifiques. Positions par mots-clés OU pixels.",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "config",
                  "value": "{\n  \"template\": \"reels-karaoke\",\n  \"overlays\": [\n    { \"type\":\"text\", \"text\":\"Intro\",   \"start\":0,  \"end\":3,  \"x\":\"left\",   \"y\":\"top\",    \"fontsize\":48, \"color\":\"#FFFFFF\", \"bg_color\":\"#000000\", \"bg_opacity\":0.7 },\n    { \"type\":\"text\", \"text\":\"@hugomorales\", \"start\":0, \"end\":99, \"x\":\"right\",  \"y\":\"bottom\", \"fontsize\":32, \"color\":\"#FFFFFF\" },\n    { \"type\":\"text\", \"text\":\"CTA: lien en bio\", \"start\":7, \"end\":12, \"x\":\"center\", \"y\":\"bottom\", \"fontsize\":56, \"color\":\"#FFFF00\", \"bg_color\":\"#000000\", \"bg_opacity\":0.8 }\n  ]\n}",
                  "type": "text"
                },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "media_1", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "Position en pixels (placement précis)",
          "request": {
            "method": "POST",
            "description": "x et y peuvent être des entiers (pixels) au lieu de mots-clés.",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "config",
                  "value": "{\"template\":\"reels-karaoke\",\"overlays\":[{\"type\":\"text\",\"text\":\"X=200 Y=900\",\"x\":200,\"y\":900,\"fontsize\":48,\"color\":\"#00FF00\"}]}",
                  "type": "text"
                },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        }
      ]
    },
    {
      "name": "7. Médias avancés",
      "item": [

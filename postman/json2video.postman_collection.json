            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "subtitle.mode = captions (blocs)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"subtitle\":{\"mode\":\"captions\",\"language\":\"fr\"}}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }

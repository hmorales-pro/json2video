    {
      "name": "9. KITCHEN SINK — tous les paramètres",
      "item": [
        {
          "name": "Tout activé (référence complète)",
          "request": {
            "method": "POST",
            "description": "Exemple exhaustif référençant chaque champ de l'API.\n\nCHAMPS TOP-LEVEL :\n- template : preset (reels-karaoke | youtube-captions | square-quote | tiktok-storytime)\n- format : slug \"9:16|16:9|1:1|4:5|21:9\" OU {width, height}\n- fps : 12-60\n- background : hex #RRGGBB (couleur de fond pour fit:contain)\n- audio_handling : extend (défaut) | loop | loop_all | cut\n- subtitle : { mode, language, style }\n- transitions : { type, duration }\n- audio : { voice_volume, music_volume, ducking }\n- overlays : [{ type:text, text, start, end, x, y, fontsize, color, bg_color, bg_opacity }]\n- media : [{ type, duration, fit, trim_start, trim_end }]\n- output : { preset, crf }",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "config",
                  "value": "{\n  \"template\": \"reels-karaoke\",\n  \"format\": \"9:16\",\n  \"fps\": 30,\n  \"background\": \"#000000\",\n  \"audio_handling\": \"extend\",\n\n  \"subtitle\": {\n    \"mode\": \"karaoke\",\n    \"language\": \"fr\",\n    \"style\": {\n      \"fontname\": \"DejaVu Sans\",\n      \"fontsize\": 64,\n      \"primary_color\":   [255,255,255,0],\n      \"secondary_color\": [0,230,255,0],\n      \"outline_color\":   [0,0,0,0],\n      \"back_color\":      [0,0,0,160],\n      \"alignment\": 2,\n      \"margin_v\": 240,\n      \"outline\": 3,\n      \"shadow\": 2,\n      \"bold\": true,\n      \"max_words_per_line\": 4\n    }\n  },\n\n  \"transitions\": {\n    \"type\": \"fade\",\n    \"duration\": 0.4\n  },\n\n  \"audio\": {\n    \"voice_volume\": 1.1,\n    \"music_volume\": 0.3,\n    \"ducking\": true\n  },\n\n  \"overlays\": [\n    {\n      \"type\": \"text\",\n      \"text\": \"Cliquez le lien en bio\",\n      \"start\": 5,\n      \"end\": 8,\n      \"x\": \"center\",\n      \"y\": \"bottom\",\n      \"fontsize\": 56,\n      \"color\": \"#FFFF00\",\n      \"bg_color\": \"#000000\",\n      \"bg_opacity\": 0.8\n    }\n  ],\n\n  \"media\": [\n    { \"duration\": 2.5, \"fit\": \"cover\" },\n    { \"duration\": \"auto\", \"fit\": \"cover\" },\n    { \"trim_start\": 0, \"trim_end\": 4, \"fit\": \"cover\" }\n  ],\n\n  \"output\": {\n    \"preset\": \"medium\",\n    \"crf\": 20\n  }\n}",
                  "type": "text"
                },
                { "key": "media_0", "type": "file", "src": "", "description": "[FILE] image 2.5s" },
                { "key": "media_1", "type": "file", "src": "", "description": "[FILE] image durée auto" },
                { "key": "media_2", "type": "file", "src": "", "description": "[FILE] vidéo trimée 0-4s" },
                { "key": "audio",   "type": "file", "src": "", "description": "[FILE] voix-off" },
                { "key": "music",   "type": "file", "src": "", "description": "[FILE] musique de fond" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        }
      ]
    },
    {
      "name": "10. Render asynchrone (queue)",
      "item": [
        {
          "name": "POST /render/async (sauvegarde job_id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.job_id) {",
                  "  pm.environment.set('last_job_id', data.job_id);",
                  "  console.log('job_id sauvé:', data.job_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\"}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render/async", "host": ["{{base_url}}"], "path": ["render", "async"] }
          }
        },
        {
          "name": "GET /jobs/:id (auto avec last_job_id)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/jobs/{{last_job_id}}",
              "host": ["{{base_url}}"],
              "path": ["jobs", "{{last_job_id}}"]
            }
          }
        },
        {
          "name": "GET /jobs (liste tous les jobs)",

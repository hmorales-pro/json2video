          "name": "Mix image + vidéo",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"media\":[{\"duration\":3},{\"trim_start\":2,\"trim_end\":8},{\"duration\":\"auto\"}]}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "", "description": "[FILE] image" },
                { "key": "media_1", "type": "file", "src": "", "description": "[FILE] vidéo (trim 2s-8s)" },
                { "key": "media_2", "type": "file", "src": "", "description": "[FILE] image" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        },
        {
          "name": "Modes fit : cover / contain / stretch",
          "request": {
            "method": "POST",
            "description": "cover = crop pour remplir, contain = letterbox, stretch = déforme.",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "config", "value": "{\"template\":\"reels-karaoke\",\"media\":[{\"duration\":3,\"fit\":\"cover\"},{\"duration\":3,\"fit\":\"contain\"},{\"duration\":3,\"fit\":\"stretch\"}]}", "type": "text" },
                { "key": "media_0", "type": "file", "src": "" },
                { "key": "media_1", "type": "file", "src": "" },
                { "key": "media_2", "type": "file", "src": "" },
                { "key": "audio",   "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/render", "host": ["{{base_url}}"], "path": ["render"] }
          }
        }
      ]
    },
    {
      "name": "8. Formats vidéo",
      "item": [
        {
          "name": "Format 9:16 (1080×1920)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
